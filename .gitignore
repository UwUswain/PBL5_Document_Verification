# --- VIRTUAL ENVIRONMENTS (CHẶN TRIỆT ĐỂ) ---
venv/
.venv/
env/
venv310/
venv*/
bin/
Include/
Lib/
Scripts/
share/
pyvenv.cfg

# --- PYTHON / BACKEND ---
__pycache__/
*.py[cod]
*$py.class
.python-version
.python-history
*.log

# --- BIẾN MÔI TRƯỜNG (BẢO MẬT) ---
.env
.env.example
!.env.example

# --- AI / YOLO / OCR ---
# Chặn folder chạy YOLO và cache của các model AI
backend/runs/
backend/datasets/
.cache/
hub/
# Chặn các file model nặng (để thầy cài requirements tự tải sau)
*.pt
*.onnx
*.engine
*.pdparams
*.pdmodel
*.pdopt

# --- STORAGE (DỮ LIỆU SINH RA KHI CHẠY) ---
# Không nên đẩy ảnh upload hoặc QR lên Git
backend/storage/uploads/*
backend/storage/qrcodes/*
backend/storage/processed/*
# Giữ lại folder nhưng bỏ qua nội dung
!backend/storage/.gitkeep
!backend/storage/uploads/.gitkeep
!backend/storage/qrcodes/.gitkeep
!backend/storage/processed/.gitkeep

# --- DATABASE ---
*.db
*.sqlite3

# --- FRONTEND ---
node_modules/
dist/
.DS_Store

# --- IDE / OS RÁC ---
.idea/
.vscode/
*.swp
*.bak
Thumbs.db
Desktop.ini
.DS_Store